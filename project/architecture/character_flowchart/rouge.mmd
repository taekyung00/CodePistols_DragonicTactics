flowchart TD
    %% --- 1. 목표 설정 및 버프 체크 ---
    Start("행동 시작") --> InitTurnVar("이번 턴 공격 여부 = False")
    InitTurnVar --> CheckHaste{"자신에게 '신속' 버프가 있는가?"}
    
    CheckHaste -- "No" --> CanHaste{"1레벨 주문 슬롯이 1개 이상인가?"}
    CanHaste -- "Yes" --> UseHaste("가속의 인장 사용")
    UseHaste --> SpendSlotHaste("1레벨 주문 슬롯 1 소모")
    SpendSlotHaste --> SpendAPHaste("행동력 1 소모")
    SpendAPHaste --> CheckHaste
    
    CheckHaste -- "Yes" --> CheckReach{"드래곤에 도달(인접 1칸)했는가?"}
    CanHaste -- "No" --> CheckReach

    %% --- 2. 이동 로직 (도달하지 못한 경우) ---
    CheckReach -- "No" --> CanIMove{"이동력이 1 이상인가?"}
    
    CanIMove -- "Yes" --> StepMove("드래곤 방향으로 1칸 이동")
    StepMove --> SpendMP("이동력 1 소모")
    SpendMP --> CheckReach
    
    %% 이동 실패 시: 공격한 적이 없고 행동력이 있다면 은신
    CanIMove -- "No" --> DidIAttackStay{"이번 턴에 공격했는가?"}
    DidIAttackStay -- "No" --> CanAPForStealthStay{"행동력이 1 이상인가?"}
    CanAPForStealthStay -- "Yes" --> UseStealthStay("그림자 숨기 사용")
    UseStealthStay --> SpendAPForStealthStay("행동력 1 소모")
    SpendAPForStealthStay --> EndTurn1("턴 종료 (은신 유지)")
    
    DidIAttackStay -- "Yes" --> EndTurn1
    CanAPForStealthStay -- "No" --> EndTurn1

    %% --- 3. 도달 시 행동 결정 (도달한 경우) ---
    CheckReach -- "Yes" --> CheckDebuff{"드래곤이 디버프 상태인가?"}
    
    %% 약점 공략 (주문 슬롯 2레벨 소모)
    CheckDebuff -- "Yes" --> HasSlotForWeak{"2레벨 주문 슬롯이 1개 이상인가?"}
    HasSlotForWeak -- "Yes" --> UseWeakness("약점 공략 사용")
    UseWeakness --> SetAttackTrue1("공격 여부 = True")
    SetAttackTrue1 --> SpendSlotWeak("2레벨 주문 슬롯 1 소모")
    SpendSlotWeak --> SpendAPWeak("행동력 1 소모")
    SpendAPWeak --> CheckMoreAction
    
    HasSlotForWeak -- "No" --> NormalAttack("일반 공격")

    %% 디버프가 없을 때의 판단
    CheckDebuff -- "No" --> KillChance{"처치 확률 30% 이하인가?"}
    
    KillChance -- "Yes" --> AlreadyStealthed{"현재 은신 상태인가?"}
    
    %% 처치 확률이 낮고 은신이 아닐 때: 이번 턴 공격 여부와 남은 행동력 확인
    AlreadyStealthed -- "No" --> DidIAttackCombat{"이번 턴에 공격했는가?"}
    DidIAttackCombat -- "No" --> CheckAPForStealthCombat{"남은 행동력이 1인가?"}
    
    CheckAPForStealthCombat -- "Yes" --> UseStealthCombat("그림자 숨기 사용")
    UseStealthCombat --> SpendAPStealthCombat("행동력 1 소모")
    SpendAPStealthCombat --> EndTurn2("턴 종료 (은신 유지)")
    
    %% 공격을 했거나 행동력이 1이 아니면 공격
    DidIAttackCombat -- "Yes" --> NormalAttack
    CheckAPForStealthCombat -- "No" --> NormalAttack
    AlreadyStealthed -- "Yes" --> NormalAttack
    KillChance -- "No" --> NormalAttack

    NormalAttack --> SetAttackTrue2("공격 여부 = True")
    SetAttackTrue2 --> SpendAPNormal("행동력 1 소모")
    SpendAPNormal --> CheckMoreAction

    %% --- 4. 추가 행동 체크 및 종료 ---
    CheckMoreAction{"행동력이 1 이상 남아있는가?"}
    CheckMoreAction -- "Yes" --> CheckReach
    CheckMoreAction -- "No" --> EndTurn3("턴 종료")