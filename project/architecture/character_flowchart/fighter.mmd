flowchart TD
    Start(["파이터 턴 시작"]) --> InitVars["상태 변수 초기화: <br> [공격 여부 = False]"]
    
    %% ---------------------------------------------------
    %% 0. 킬캐치 진입 검증
    %% ---------------------------------------------------
    InitVars --> CheckKillDist{"A* 경로 탐색: <br> 이번 턴 내 도달 가능한가?"}
    
    CheckKillDist -- Yes --> CheckKillHP{"드래곤 확정 처치 가능한가? <br> (가용 슬롯 총합 데미지 계산)"}
    CheckKillHP -- Yes --> Kill_Loop

    CheckKillDist -- No --> Phase_Decision
    CheckKillHP -- No --> Phase_Decision

    subgraph Kill_Loop ["최고 화력 집중 루프"]
        K_Reach{"인접?"} -- No --> K_CanMove{"MP > 0?"}
        K_CanMove -- Yes --> K_DoMove["이동 (MP-1)"] --> K_Reach
        K_CanMove -- No --> Phase_Decision
        
        K_Reach -- Yes --> K_AP{"AP > 0?"} -- Yes --> K_BestSlot{"적 체력에 맞는 <br> 최적 슬롯 탐색"}
        K_BestSlot -- 슬롯있음 --> K_Smite["강타 (AP-1) <br> [오버킬 방지 업캐스팅]"] --> K_AP
        K_BestSlot -- 슬롯없음 --> K_Norm["일반 공격 (AP-1)"] --> K_AP
        K_AP -- No --> End_K(["턴 종료"])
    end

    %% ---------------------------------------------------
    %% 1. 판단 지점
    %% ---------------------------------------------------
    Phase_Decision(("판단 지점")) --> CheckAP{"남은 AP > 0?"}
    CheckAP -- No --> End(["턴 종료"])

    CheckAP -- Yes --> CheckReach{"드래곤 인접(1칸)?"}

    %% [이동 구간]
    CheckReach -- No --> CanMove{"MP > 0 & A* 경로 있음?"}
    CanMove -- Yes --> Act_Move["이동 (MP-1)"] --> Phase_Decision
    
    %% [보완] 이동 불가 시 공포 사거리 체크 후 시전
    CanMove -- No --> CheckFearFar{"드래곤 공포 없음 & 1레벨 슬롯 있음 <br> & 공포 사거리 내에 있는가?"}
    CheckFearFar -- Yes --> Act_FearFar["공포의 외침 (AP-1)"] --> End
    CheckFearFar -- No --> End

    %% [교전 구간]
    CheckReach -- Yes --> CheckHP{"HP 40% 이하인가?"}

    %% ---------------------------------------------------
    %% 2. 생존 시퀀스 (피의 갈망 투자형)
    %% ---------------------------------------------------
    CheckHP -- Yes --> HasBloodlust{"'피의 갈망' 상태?"}
    
    %% 일반 공격으로도 회복되므로, AP 1만 있어도 버프를 거는 이득이 있음
    HasBloodlust -- No --> CheckBloodSlot{"2레벨 슬롯 있음?"}
    CheckBloodSlot -- Yes --> Act_Bloodlust["피의 갈망 시전 (AP-1) <br> (다음 공격부터 피흡 적용)"] --> Phase_Decision
    CheckBloodSlot -- No --> CheckFearNear{"드래곤 '공포' 없음?"}

    HasBloodlust -- Yes --> CheckHealSlot{"강타용 슬롯 있음?"}
    CheckHealSlot -- 슬롯있음 --> Act_HealSmite["강타 (AP-1) <br> [피흡 극대화 업캐스팅]"] --> Phase_Decision
    CheckHealSlot -- 슬롯없음 --> Act_NormalLoop["일반 공격 (AP-1) <br> (피의 갈망 효과로 회복)"] --> Phase_Decision

    %% ---------------------------------------------------
    %% 3. 일반 교전 로직
    %% ---------------------------------------------------
    CheckHP -- No --> CheckBless{"'축복' 적용 중?"}
    
    CheckBless -- Yes --> HasBurst{"'격앙' 버프 상태?"}
    HasBurst -- No --> CheckBurstAP{"남은 AP >= 2?"}
    CheckBurstAP -- Yes --> Act_Burst["격앙 시전 (AP-1)"] --> Phase_Decision
    CheckBurstAP -- No --> CheckSmiteSlot
    
    HasBurst -- Yes --> CheckSmiteSlot
    
    CheckSmiteSlot{"공격용 슬롯 있음?"} -- 슬롯있음 --> Act_UpSmite["강타 (AP-1) <br> [가용한 최고레벨 소모]"] --> Phase_Decision
    CheckSmiteSlot -- 슬롯없음 --> Act_NormalLoop["일반 공격 (AP-1)"] --> Phase_Decision

    %% 클레릭 연계
    CheckBless -- No --> CheckCleric{"클레릭 생존?"}
    CheckCleric -- Yes --> CheckFearNear
    
    %% [보완] 인접 시에도 공포 사거리 체크 (보통 인접 시 사거리는 무조건 충족)
    CheckFearNear -- Yes (공포없음) --> CheckFearSlot{"1레벨 슬롯 있음 & <br> 공포 사거리 내에 있는가?"}
    CheckFearSlot -- Yes --> Act_Fear["공포의 외침 (AP-1)"] --> Phase_Decision
    CheckFearSlot -- No --> Act_NormalLoop
    CheckFearNear -- No (이미공포) --> Act_NormalLoop

    %% 클레릭 부재 시 로직
    CheckCleric -- No --> HasIndBurst{"'격앙' 상태인가?"}
    HasIndBurst -- No --> Check2ndSlot{"2레벨 슬롯 있음 & <br> AP >= 2?"}
    Check2ndSlot -- Yes --> Act_IndBurst["격앙 시전 (AP-1)"] --> Phase_Decision
    Check2ndSlot -- No --> CheckFearNear
    HasIndBurst -- Yes --> CheckSmiteSlot
