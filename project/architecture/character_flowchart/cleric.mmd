flowchart TD
    Start(["클레릭 턴 시작"]) --> Init["상태 초기화 <br> (MP/AP/가용 슬롯 확인)"]

    %% [0단계: 슬롯 상태 업데이트]
    Init --> CheckAnySlots{"가용 슬롯 <br> 1개라도 있음?"}
    CheckAnySlots -- "No (슬롯 0)" --> SetNoSlotState["상태 설정: '지원 불가능' <br> (IsSupportAvailable = False)"] --> MeleePhase
    CheckAnySlots -- "Yes" --> SetSlotState["상태 설정: '지원 가능' <br> (IsSupportAvailable = True)"] --> CheckKill

    %% [1단계: 확정 킬 시퀀스]
    CheckKill{"[1순위] 확정 킬 가능?"}
    CheckKill -- "Yes" --> Kill_Loop
    
    subgraph Kill_Loop ["최고 화력 집중 루프"]
        K_Move{"인접함?"} -- No --> K_MP{"MP > 0?"}
        K_MP -- Yes --> K_DoMove["이동 (MP-1)"] --> K_Move
        K_MP -- No --> Phase_Decision
        
        K_Move -- Yes --> K_AP{"AP > 0?"}
        K_AP -- Yes --> K_Slot{"슬롯 있음?"}
        K_Slot -- No --> K_Norm["일반 공격 (AP-1)"] --> K_AP
        K_AP -- No --> End_K(["턴 종료"])
    end

    %% [2단계: 판단 지점]
    CheckKill -- No --> Phase_Decision
    Phase_Decision(("판단 지점")) --> HasAP{"AP > 0?"}
    HasAP -- No --> End(["턴 종료"])

    %% [3단계: 우선순위 기반 행동]
    HasAP -- Yes --> CheckHeal{"[2순위] 치유의 손길(Healing Touch) 필요?"}
    
    %% 힐링 섹션 (슬롯 체크 포함)
    CheckHeal -- "Yes" --> CanHeal{"슬롯 있음?"}
    CanHeal -- Yes --> HealAct["치유의 손길(Healing Touch) 시전 (AP-1, Slot-1)"] --> UpdateSlotCheck
    CanHeal -- No --> MeleePhase 

    %% 성스러운 가호(Divine Shield)/고통의 저주(Curse of Suffering) 상세 로직
    CheckHeal -- No --> SupportLogic{서포트 체크}
    
    SupportLogic --> AllyBuffCheck{"[3순위] 성스러운 가호(Divine Shield) 필요? <br> (파이터>로그>위자드)"}
    AllyBuffCheck -- "Yes" --> CastBuff["성스러운 가호(Divine Shield) 시전 (AP-1, Slot-1)"] --> UpdateSlotCheck
    
    AllyBuffCheck -- "No" --> DragonDebuffCheck{"[4순위] 드래곤 <br> 고통의 저주(Curse of Suffering) 필요?"}
    DragonDebuffCheck -- "Yes" --> CastDebuff["고통의 저주(Curse of Suffering) 시전 (AP-1, Slot-1)"] --> UpdateSlotCheck
    DragonDebuffCheck -- "No" --> MeleePhase

    %% 슬롯 소모 후 상태 업데이트
    UpdateSlotCheck["남은 슬롯 확인"] --> RemainingSlots{"슬롯 > 0?"}
    RemainingSlots -- No --> SetNoSlotState
    RemainingSlots -- Yes --> Phase_Decision
    
    subgraph MeleePhase ["기본 공격 프로세스"]
        M_Adj{"드래곤 인접?"} -- No --> M_Move{"MP > 0?"}
        M_Move -- Yes --> M_DoMove["드래곤에게 이동 (MP-1)"] --> M_Adj
        M_Move -- No --> Phase_Decision
        
        M_Adj -- Yes --> M_Atk["일반 공격 (AP-1)"] --> Phase_Decision
    end

    %% [4단계: 마무리]
    Phase_Decision --> HasMP{"AP는 없지만 <br> MP가 남았는가?"}
    HasMP -- Yes --> TacticalMove["다음 턴 대비 위치 이동"] --> End
    HasMP -- No --> End